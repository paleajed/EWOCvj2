{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "${MODEL_NAME}"
    }
  },
  "2": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "${INPUT_VIDEO}",
      "force_rate": 0,
      "force_size": "Disabled",
      "custom_width": "${WIDTH}",
      "custom_height": "${HEIGHT}",
      "frame_load_cap": "${FRAMES}",
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "3": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["2", 0],
      "vae": ["1", 2]
    }
  },
  "4": {
    "class_type": "ADE_AnimateDiffLoaderWithContext",
    "inputs": {
      "model_name": "mm_sd_v15_v2.fp16.safetensors",
      "beta_schedule": "sqrt_linear (AnimateDiff)",
      "motion_scale": 1.0,
      "apply_v2_models_properly": true,
      "model": ["1", 0],
      "context_options": ["5", 0]
    }
  },
  "5": {
    "class_type": "ADE_StandardStaticContextOptions",
    "inputs": {
      "context_length": "${CONTEXT_LENGTH}",
      "context_stride": 1,
      "context_overlap": "${CONTEXT_OVERLAP}",
      "closed_loop": "${SEAMLESS_LOOP}",
      "fuse_method": "pyramid",
      "use_on_equal_length": false
    }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "${PROMPT}",
      "clip": ["1", 1]
    }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "${NEGATIVE_PROMPT}",
      "clip": ["1", 1]
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "${SEED}",
      "steps": "${STEPS}",
      "cfg": "${CFG_SCALE}",
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": "${REMIX_STRENGTH}",
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["3", 0]
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    }
  },
  "10": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "frame_rate": "${FPS}",
      "loop_count": 0,
      "filename_prefix": "remix",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "images": ["9", 0]
    }
  }
}
