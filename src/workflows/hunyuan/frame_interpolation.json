{
  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "${INPUT_VIDEO}",
      "force_rate": 0,
      "force_size": "Disabled",
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1
    }
  },
  "2": {
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife47.pth",
      "clear_cache_after_n_frames": 10,
      "multiplier": "${INTERPOLATION_FACTOR}",
      "fast_mode": true,
      "ensemble": false,
      "scale_factor": 1.0,
      "frames": ["1", 0]
    }
  },
  "3": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["2", 0],
      "filename_prefix": "interpolated/${BATCH_ID}/frame"
    }
  }
}
