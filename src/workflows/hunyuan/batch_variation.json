{
  "1": {
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "hunyuanvideo1.5_720p_t2v-Q4_K_M.gguf"
    },
    "_meta": {
      "title": "Load Diffusion Model"
    }
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
      "clip_name2": "byt5_small_glyphxl_fp16.safetensors",
      "type": "hunyuan_video_15"
    },
    "_meta": {
      "title": "Load CLIP"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "hunyuanvideo15_vae_fp16.safetensors"
    },
    "_meta": {
      "title": "Load VAE"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "${PROMPT}"
    },
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "5": {
    "class_type": "EmptyHunyuanLatentVideo",
    "inputs": {
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "length": "${FRAMES}",
      "batch_size": 1
    },
    "_meta": {
      "title": "Create Latent Video"
    }
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {
      "conditioning": ["4", 0],
      "guidance": 6.0
    },
    "_meta": {
      "title": "Flux Guidance"
    }
  },
  "7": {
    "class_type": "ModelSamplingSD3",
    "inputs": {
      "model": ["1", 0],
      "shift": 9.0
    },
    "_meta": {
      "title": "Configure Sampler"
    }
  },
  "8": {
    "class_type": "BasicScheduler",
    "inputs": {
      "model": ["7", 0],
      "scheduler": "normal",
      "steps": "${STEPS}",
      "denoise": 1.0
    },
    "_meta": {
      "title": "Create Noise Schedule"
    }
  },
  "9": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": "${SEED}"
    },
    "_meta": {
      "title": "Random Noise"
    }
  },
  "10": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    },
    "_meta": {
      "title": "Select Sampler"
    }
  },
  "11": {
    "class_type": "BasicGuider",
    "inputs": {
      "model": ["7", 0],
      "conditioning": ["6", 0]
    },
    "_meta": {
      "title": "Basic Guidance"
    }
  },
  "12": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["9", 0],
      "guider": ["11", 0],
      "sampler": ["10", 0],
      "sigmas": ["8", 0],
      "latent_image": ["5", 0]
    },
    "_meta": {
      "title": "Generate (Diffusion Sampling)"
    }
  },
  "13": {
    "class_type": "VAEDecodeTiled",
    "inputs": {
      "vae": ["3", 0],
      "samples": ["12", 0],
      "tile_size": 128,
      "overlap": 32,
      "temporal_size": 32,
      "temporal_overlap": 4
    },
    "_meta": {
      "title": "Decode Video (VAE)"
    }
  },
  "14": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["13", 0],
      "filename_prefix": "hunyuan_batch/${BATCH_ID}/frame"
    },
    "_meta": {
      "title": "Save Frames"
    }
  }
}
